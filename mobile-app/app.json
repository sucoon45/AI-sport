{
  "expo": {
    "name": "BetMind AI - Predictions & Tips",
    "slug": "betmind-ai",
    "version": "1.0.4",
    "description": "Premium AI-powered sports predictions and football analytics with BetMind AI.",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kamirex.aisport",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow AI SPORT to access your camera for profile picture updates."
      }
    },
    "android": {
      "package": "com.kamirex.aisport",
      "adaptiveIcon": {
        "backgroundColor": "#0B0E14",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
